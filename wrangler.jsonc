{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "borang-pa",
  "main": "worker.js",
  "compatibility_date": "2026-05-13",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "cert_db",
      "database_id": "42d5686a-4ffc-4831-8f90-e3487a8e5bcc"
    }
  ]
}
